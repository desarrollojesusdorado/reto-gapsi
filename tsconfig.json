{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "@playwright/test"],
    "baseUrl": ".",
    "paths": {
      "@api/*": ["src/api/*"],
      "@fixtures/*": ["src/fixtures/*"],
      "@contracts/*": ["src/types/*"]
    }
  },
  "include": ["playwright.config.ts", "src/**/*.ts", "tests/**/*.ts"]
}
