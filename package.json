{
  "name": "reto-gapsi-playwright-api",
  "version": "1.0.0",
  "description": "Automatizacion tecnica API con Playwright, TypeScript y patron POM.",
  "private": true,
  "scripts": {
    "ci": "npm run typecheck && npm run test:ci",
    "test": "playwright test",
    "test:api": "playwright test tests/api",
    "test:ci": "playwright test tests/api",
    "test:headed": "playwright test --headed",
    "typecheck": "tsc --noEmit",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5"
  }
}
